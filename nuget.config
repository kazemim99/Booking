<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Booksy is a standalone repository; all package dependencies are public.
    Clear any inherited (user/machine) feeds — e.g. the private Exino feeds —
    and restore solely from nuget.org so builds don't depend on private infra.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
