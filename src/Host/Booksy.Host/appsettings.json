  "Security": {
    "PasswordPolicy": {
      "RequiredLength": 8,
      "RequireDigit": true,
      "RequireLowercase": true,
      "RequireUppercase": true,
      "RequireNonAlphanumeric": true,
      "RequiredUniqueChars": 4
    },
    "Lockout": {
      "MaxFailedAccessAttempts": 5,
      "LockoutDuration": 15
    },
    "TwoFactor": {
      "Issuer": "Booksy",
      "TokenLifespan": 300
    }
  },
  "ServiceCatalog": {
    "MaxServicesPerProvider": 50,
    "MaxServiceImageSizeMB": 5,
    "DefaultCurrency": "USD",
    "MaxServiceNameLength": 200,
    "MaxServiceDescriptionLength": 2000,
    "MinServiceDurationMinutes": 5,
    "MaxServiceDurationMinutes": 1440,
    "MaxAdvanceBookingDays": 365,
    "DefaultMaxAdvanceBookingDays": 90,
    "AllowedImageFormats": [ "jpg", "jpeg", "png", "webp" ],
    "PricingRules": {
      "MaxServicePrice": 10000.00,
      "MinServicePrice": 0.01,
      "MaxDepositPercentage": 100.0,
      "AllowedCurrencies": [ "USD", "EUR", "GBP", "CAD", "AUD" ]
    }
  },
  "Search": {
    "Provider": "PostgreSQL",
    "MaxResults": 100,
    "DefaultPageSize": 20,
    "MaxPageSize": 100,
    "EnableFullTextSearch": true,
    "SearchTimeout": 5000,
    "LocationSearch": {
      "DefaultRadiusKm": 10.0,
      "MaxRadiusKm": 100.0,
      "EnableGeoLocation": true
