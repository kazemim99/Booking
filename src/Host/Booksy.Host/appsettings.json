    "Audience": "https://booksy.com",
    "TokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "Cache": {
    "Provider": "Redis",
    "KeyPrefix": "booksy",
    "DefaultExpirationMinutes": 15,
    "SlidingExpiration": true,
