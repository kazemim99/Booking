  "Validation": {
    "BusinessRules": {
      "EnableProviderVerification": true,
      "RequireBusinessLicense": false,
      "EnableServiceApproval": false,
      "MaxTagsPerService": 10,
      "MaxOptionsPerService": 20,
      "MaxPriceTiersPerService": 5
    },
    "ContentModeration": {
      "EnableProfanityFilter": true,
      "EnableContentScanning": true,
      "RequireImageModeration": false
    }
  },
  "Payment": {
