    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://localhost:5173",
      "http://localhost:5174",
      "http://localhost:7002",
      "https://booksy.com",
      "https://app.booksy.com"
    ]
